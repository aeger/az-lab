# LLDAP Configuration
LLDAP_JWT_SECRET=your-jwt-secret-here
LLDAP_KEY_SEED=your-key-seed-here
LLDAP_LDAP_BASE_DN=dc=az-lab,dc=dev
LLDAP_LDAP_USER_DN=admin
LLDAP_LDAP_USER_PASS=your-admin-password
LLDAP_LDAP_PORT=3890
LLDAP_HTTP_PORT=17170
LLDAP_HTTP_URL=https://lldap.az-lab.dev
LLDAP_SMTP_OPTIONS__ENABLE_PASSWORD_RESET=true
LLDAP_SMTP_OPTIONS__SERVER=smtp-relay.brevo.com
LLDAP_SMTP_OPTIONS__PORT=587
LLDAP_SMTP_OPTIONS__USER=your-smtp-user
LLDAP_SMTP_OPTIONS__PASSWORD=your-smtp-password
LLDAP_SMTP_OPTIONS__FROM=lldap@az-lab.dev
LLDAP_SMTP_OPTIONS__REPLY_TO=jeff@az-lab.dev
LLDAP_SMTP_OPTIONS__TLS_REQUIRED=true
TZ=America/Phoenix
